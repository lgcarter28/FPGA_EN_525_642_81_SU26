					<ul class="list-unstyled" style="visibility: hidden;background-color: transparent;color: #333333;text-decoration: none;-webkit-tap-highlight-color: transparent;font-weight: 400;letter-spacing: 0;font-size: 12px;line-height: 24px;padding: 0;margin: 0px;-webkit-print-color-adjust: exact;padding-left: 0;list-style: none">
									<li style="visibility: hidden;background-color: transparent;color: #333333;text-decoration: none;-webkit-tap-highlight-color: transparent;-webkit-print-color-adjust: exact">
										<div style="visibility: hidden;background-color: transparent;color: #333333;text-decoration: none;-webkit-tap-highlight-color: transparent;-webkit-print-color-adjust: exact;display: inline-flex;align-items: top">
												<div style="visibility: hidden;background-color: transparent;color: #333333;text-decoration: none;-webkit-tap-highlight-color: transparent;-webkit-print-color-adjust: exact;width: 45px;padding: 10px 5px 10px 0px">
													<div aria-hidden="true" class="circle medium mdl-color--deep-purple mdl-color-text--white" style="visibility: hidden;background-color: #673ab7 !important;color: #fff !important;text-decoration: none;-webkit-tap-highlight-color: transparent;-webkit-print-color-adjust: exact;border-radius: 50%;text-align: center;display: inline-block;position: relative;width: 38px;height: 38px;font-size: 1.3em;line-height: 48px;background: #ddd">
														<div class="circle--inner" style="visibility: hidden;background-color: transparent;color: #ffffff;text-decoration: none;-webkit-tap-highlight-color: transparent;-webkit-print-color-adjust: exact;width: 36px;height: 36px;position: absolute;margin: auto;top: 0;right: 0;bottom: 0;left: 0">
															<i style="visibility: hidden;background-color: transparent;color: #333333;text-decoration: none;-webkit-tap-highlight-color: transparent;-webkit-print-color-adjust: exact"></i>
														</div>
													</div>
